# ==========================================
# テスト用 DB 接続設定
# ==========================================
# このファイルをコピーして .env.test を作成してください
#
#   cp .env.test.example .env.test
#
# テスト用 DB コンテナ (db-test) はポート 5435 を使用しています。
# docker/local/compose.yaml の db-test サービスを参照してください。

DATABASE_URL="postgresql://root:password@localhost:5435/tumiki_test"

# Prismaフィールド暗号化設定（prisma db push 実行時に参照されます）
# テスト・開発専用のダミーキーのためそのまま使用できます
PRISMA_FIELD_ENCRYPTION_KEY="k1.aesgcm256.kG588VHXtTCncg2y9KmbXqyssLulxqUjrSn9_TXFu2U="
PRISMA_FIELD_ENCRYPTION_HASH_SALT="test-salt-for-db-push-only"
