# Tumiki ステージング環境 環境変数
# このファイルを .env にコピーして値を設定してください

# ===================================
# データベース設定
# ===================================
DB_USER=tumiki
DB_PASSWORD=<generate-secure-password>
DB_NAME=tumiki

# ===================================
# Keycloak 設定
# ===================================
# Keycloak 管理者認証情報
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=<generate-secure-password>

# Keycloak データベースパスワード
KEYCLOAK_DB_PASSWORD=<generate-secure-password>

# Keycloak クライアント認証情報（Terraform で作成後に設定）
KEYCLOAK_CLIENT_ID=tumiki-manager
KEYCLOAK_CLIENT_SECRET=<keycloak-client-secret>

# ===================================
# Prisma 暗号化キー
# ===================================
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# または: openssl rand -base64 32
PRISMA_FIELD_ENCRYPTION_KEY=k1.aesgcm256.<generate-key>

# ===================================
# Docker イメージタグ
# ===================================
# main (最新), sha-xxxxx (特定コミット), v1.0.0 (リリースタグ)
MANAGER_IMAGE_TAG=main
MCP_PROXY_IMAGE_TAG=main

# ===================================
# アプリケーション設定
# ===================================
# ee (Enterprise Edition) または ce (Community Edition)
TUMIKI_EDITION=ee

# ===================================
# オプション: Pub/Sub ログ送信
# ===================================
# Google Cloud Pub/Sub トピック名（オプション）
# PUBSUB_MCP_LOGS_TOPIC=projects/your-project/topics/mcp-logs
