# docker/apps/compose.*.yaml で参照される環境変数のサンプル
#
# 本番デプロイは GitHub Actions (deploy-apps.yml) が Infisical からシークレットを取得し
# VM 上の ~/tumiki/.env として書き出すため、通常このファイルを直接コピーする必要はない。
# 手動デプロイや動作確認時の参照用。

# ===== Image tag =====
# Watchtower 利用時は :latest 固定で運用（リリースタグ push でのみ更新）。
# 手動でロールバックする場合のみ特定バージョン (例: 1.2.3) を指定。
IMAGE_TAG=latest

# ===== Database (compose 内 db を使う staging のみ) =====
POSTGRES_PASSWORD=

# ===== Manager / Internal Manager Auth =====
# 公開 URL（AUTH_URL / NEXTAUTH_URL の上書きに使用）
NEXTAUTH_URL=https://manager.tumiki.cloud
NEXTAUTH_URL_INTERNAL_MANAGER=

# ===== Object Storage (staging で MinIO を使う場合のみ必要) =====
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
OBJECT_STORAGE_BUCKET=tumiki-assets
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_PUBLIC_BASE_URL=

# ===== Watchtower (production 自動更新) =====
# ポーリング間隔（秒）。GHCR の rate limit に配慮して 300 秒以上推奨
WATCHTOWER_POLL_INTERVAL=300

# Shoutrrr 形式の通知 URL。空なら通知無効。
# Slack 例: slack://hook:T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX@channel
# 詳細: https://containrrr.dev/shoutrrr/
WATCHTOWER_NOTIFICATION_URL=
