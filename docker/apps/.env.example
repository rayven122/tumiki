# docker/apps/compose.*.yaml で参照される環境変数のサンプル
#
# === production ===
# 本番環境では Infisical を SoT として運用しており、本ファイルを直接コピーする
# 必要はない。VM 上の systemd timer (tumiki-secrets-sync) が `infisical export` で
# ~/tumiki/.env を生成・更新する。Infisical 上に登録すべき変数の確認用に参照する。
#
# === staging ===
# staging も GitHub Actions が Infisical からシークレットを取得して .env を配置する。
# 手動デプロイや動作確認時のみ本ファイルをコピーして利用する。

# ===== Image tag =====
# Watchtower 利用時は :latest 固定で運用（リリースタグ push でのみ更新）。
# 手動でロールバックする場合のみ特定バージョン (例: 1.2.3) を指定。
IMAGE_TAG=latest

# ===== Database (compose 内 db を使う staging のみ) =====
POSTGRES_PASSWORD=

# ===== Manager / Internal Manager Auth =====
# 公開 URL（AUTH_URL / NEXTAUTH_URL の上書きに使用）
NEXTAUTH_URL=https://manager.tumiki.cloud
NEXTAUTH_URL_INTERNAL_MANAGER=

# ===== Object Storage (staging で MinIO を使う場合のみ必要) =====
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
OBJECT_STORAGE_BUCKET=tumiki-assets
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_PUBLIC_BASE_URL=

# ===== Watchtower (production の image 自動更新) =====
# ポーリング間隔（秒）。GHCR の rate limit に配慮して 300 秒以上推奨
WATCHTOWER_POLL_INTERVAL=300

# Watchtower の image 更新中に secrets-sync が過剰 reconcile しないための猶予秒数。
# manager の start_period 60 秒より余裕を持たせるため 120 秒以上を推奨。
WATCHTOWER_RECONCILE_GRACE_SEC=120

# Shoutrrr 形式の通知 URL。空なら通知無効。
# Slack 例: slack://hook:T0000/B0000/XXXXXXXX@channel
# 詳細: https://containrrr.dev/shoutrrr/
WATCHTOWER_NOTIFICATION_URL=

# GHCR package を private に変更する場合は、VM 上で `docker login ghcr.io` を実行し、
# 生成された Docker config.json を watchtower へ /config.json として read-only mount する。
# 例: /home/ubuntu/.docker/config.json:/config.json:ro
