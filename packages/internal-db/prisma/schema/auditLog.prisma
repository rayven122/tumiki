/// @namespace AuditLog
/// Desktop（PER_USER直接接続）からの監査ログ
/// mcpServerIdはpackages/dbのMcpServer.idと対応（FK制約なし・DBが分離しているため）
model DesktopAuditLog {
  id String @id @default(cuid())

  /// Desktopインストール単位の識別子（再送時の重複排除に使用）
  /// 既存行を壊さないためnullable。APIでは新規受信時に必須。
  /// APIで両フィールドを必須にしているため、NULLを含む重複キーは新規発生しない。
  sourceInstallationId String?
  /// DesktopローカルDBのAuditLog.id（sourceInstallationId内で一意）
  /// 既存行を壊さないためnullable。APIでは新規受信時に必須。
  /// APIで両フィールドを必須にしているため、NULLを含む重複キーは新規発生しない。
  sourceAuditLogId     Int?

  /// 実行ユーザー
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// 対象MCPサーバーID（packages/dbのMcpServer.idと対応）
  mcpServerId    String
  /// Desktop側の接続表示名（接続削除後もログで識別できるように保存）
  connectionName String? @db.VarChar(255)
  /// 呼び出し元AIクライアント名
  clientName     String? @db.VarChar(100)
  /// 呼び出し元AIクライアントバージョン
  clientVersion  String? @db.VarChar(50)
  /// Desktop側で記録したトランスポートタイプ
  transportType  String? @db.VarChar(32)

  /// 実行されたツール名
  toolName    String @db.VarChar(255)
  /// MCPメソッド（例: "tools/call"）
  method      String @db.VarChar(64)
  /// HTTPステータスコード
  httpStatus  Int    @db.SmallInt
  /// 実行時間（ミリ秒）
  durationMs  Int
  /// 入力データサイズ（バイト）
  inputBytes  Int
  /// 出力データサイズ（バイト）
  outputBytes Int

  /// エラー情報（エラー発生時のみ）
  errorCode    Int?
  errorSummary String? @db.VarChar(500)

  /// Desktopで記録したリクエスト発生時刻
  occurredAt DateTime
  createdAt  DateTime @default(now())

  @@unique([sourceInstallationId, sourceAuditLogId])
  @@index([userId, occurredAt])
  @@index([mcpServerId, occurredAt])
  @@index([clientName, occurredAt])
  @@index([connectionName, occurredAt])
}
