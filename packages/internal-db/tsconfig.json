{
  "extends": "@tumiki/tsconfig/node.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "emitDeclarationOnly": false,
    "allowJs": false,
    "checkJs": false,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "generated", "prisma.config.ts"]
}
