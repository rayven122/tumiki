# ==========================================
# Tumiki - Environment Variables Template
# ==========================================

# ------------------------------------------
# データベース設定 (🔴 必須)
# ------------------------------------------
DATABASE_URL="postgresql://root:password@localhost:5434/tumiki"
DESKTOP_DATABASE_URL="file:./tumiki-desktop.db"  # Desktop用SQLite (🟡 Desktop使用時に必須)

# ------------------------------------------
# Prismaフィールド暗号化設定 (🔴 必須)
# ------------------------------------------
# CI/テスト環境用のダミーキー（本番環境では必ず変更すること）
PRISMA_FIELD_ENCRYPTION_KEY="k1.aesgcm256.kG588VHXtTCncg2y9KmbXqyssLulxqUjrSn9_TXFu2U="
# PRISMA_FIELD_DECRYPTION_KEYS="generate-with-cloak-library"  # オプション: キーローテーション時のみ使用
PRISMA_FIELD_ENCRYPTION_HASH_SALT="generate-with-openssl-rand-base64-32"

# ------------------------------------------
# Redis設定 (🔴 必須)
# ------------------------------------------
REDIS_URL="redis://localhost:6379"
# REDIS_CONNECT_TIMEOUT=10000  # オプション: Redis接続タイムアウト（ミリ秒）
REDIS_ENCRYPTION_KEY="generate-with-node-crypto-randomBytes-32-hex"

# ------------------------------------------
# Keycloak認証設定 (🔴 必須)
# ------------------------------------------
KEYCLOAK_CLIENT_ID="tumiki-manager"
KEYCLOAK_CLIENT_SECRET="tumiki-manager-secret-change-in-production"
KEYCLOAK_PROXY_CLIENT_SECRET="tumiki-proxy-secret-change-in-production"
KEYCLOAK_ISSUER="http://localhost:8443/realms/tumiki"
KEYCLOAK_ADMIN_USERNAME="admin"
KEYCLOAK_ADMIN_PASSWORD="admin123"
KEYCLOAK_TEST_USER_PASSWORD="admin123"
KEYCLOAK_DESKTOP_CLIENT_ID="tumiki-desktop"

# ------------------------------------------
# Auth.js設定 (🔴 必須)
# ------------------------------------------
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ------------------------------------------
# MCP Proxy設定 (🔴 必須)
# ------------------------------------------
NEXT_PUBLIC_MCP_PROXY_URL="http://localhost:8080"

# ------------------------------------------
# キャッシュ設定 (🟢 任意)
# ------------------------------------------
# CACHE_TTL=300  # オプション: キャッシュ有効期限（秒）

# ------------------------------------------
# メール送信設定 (🟢 任意)
# ------------------------------------------
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# FROM_EMAIL="info@tumiki.cloud"

# ------------------------------------------
# MicroCMS設定 (🟢 任意)
# ------------------------------------------
# MICROCMS_TUMIKI_BLOG_API_KEY=""
# MICROCMS_TUMIKI_BLOG_SERVICE_DOMAIN="tumiki"

# ------------------------------------------
# メンテナンスモード設定 (🟢 任意)
# ------------------------------------------
# MAINTENANCE_MODE=false
# MAINTENANCE_ALLOWED_IPS=""
# NEXT_PUBLIC_MAINTENANCE_END_TIME=""

# ------------------------------------------
# Desktop App設定 (🟡 Desktop開発時のみ)
# ------------------------------------------
DESKTOP_DATABASE_URL="file:./desktop.db"

# ------------------------------------------
# 開発・デバッグ設定 (🟢 任意)
# ------------------------------------------
# DEBUG_MULTITENANCY=false
# LOG_LEVEL="info"

# ==========================================
# 暗号化キーの生成方法
# ==========================================
# AUTH_SECRET, PRISMA_FIELD_ENCRYPTION_HASH_SALT:
#   openssl rand -base64 32
#
# REDIS_ENCRYPTION_KEY:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# PRISMA_FIELD_ENCRYPTION_KEY:
#   Cloakライブラリを使用（詳細はPrisma Field Encryptionドキュメント参照）
#   https://cloak.47ng.com/
#
# PRISMA_FIELD_DECRYPTION_KEYS (オプション):
#   キーローテーション時に古いキーで暗号化されたデータを復号化するために使用
#   カンマ区切りで複数の古いキーを指定可能
#   例: PRISMA_FIELD_DECRYPTION_KEYS="old-key-1,old-key-2"

# ------------------------------------------
# Internal Manager 設定 (🟡 internal-manager使用時に必須)
# ------------------------------------------
# Auth.js シークレット（internal-manager 専用）
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# OIDC プロバイダー設定（社内 IdP との連携）
# Entra ID:  OIDC_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
# GWS:       OIDC_ISSUER=https://accounts.google.com
# Okta:      OIDC_ISSUER=https://{your-domain}.okta.com
# Keycloak:  OIDC_ISSUER=https://{keycloak-host}/realms/{realm-name}
# Local Keycloak: pnpm setup:dev で作成される internal-manager 用 client
# 本番環境では必ず実際の IdP 設定と secret に差し替えてください。
OIDC_CLIENT_ID="tumiki-internal-manager"
OIDC_CLIENT_SECRET="tumiki-internal-manager-secret"
OIDC_ISSUER="http://localhost:8888/realms/tumiki"
# ローカル検証用。production では無効化されます。
INTERNAL_MANAGER_BOOTSTRAP_ADMIN_EMAIL="admin@tumiki.local"

# お問い合わせフォーム Slack 通知（未設定時はログ出力のみ）
# SLACK_CONTACT_WEBHOOK_URL="https://hooks.slack.com/services/XXXX/XXXX/XXXX"

# 面談予約 URL（お問い合わせ完了ページに表示、未設定時は非表示）
# NEXT_PUBLIC_CALENDAR_URL=""
