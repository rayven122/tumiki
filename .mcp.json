{
  "mcpServers": {
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--enable-web-dashboard",
        "false",
        "--context",
        "ide-assistant",
        "--project",
        "."
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "linear": {
      "type": "sse",
      "url": "https://mcp.linear.app/sse"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "next-devtools": {
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"]
    },
    "postgres": {
      "command": "uv",
      "args": ["run", "postgres-mcp", "--access-mode=unrestricted"],
      "env": {
        "DATABASE_URI": "${DATABASE_URL}"
      }
    },
    "sequential-thinking-stdio": {
      "command": "/Users/koji.iwase/dev/rayven/tumiki/node_modules/.pnpm/electron@40.8.0/node_modules/electron/dist/Electron.app/Contents/MacOS/Electron",
      "args": ["/Users/koji.iwase/dev/rayven/tumiki/apps/desktop", "--mcp-proxy", "--server", "sequential-thinking-stdio"]
    },
    "serena-stdio": {
      "command": "/Users/koji.iwase/dev/rayven/tumiki/node_modules/.pnpm/electron@40.8.0/node_modules/electron/dist/Electron.app/Contents/MacOS/Electron",
      "args": ["/Users/koji.iwase/dev/rayven/tumiki/apps/desktop", "--mcp-proxy", "--server", "serena-stdio"]
    }
  }
}
