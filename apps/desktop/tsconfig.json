{
  "extends": "@tumiki/tsconfig/base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@prisma/desktop-client": ["./prisma/generated/client"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist-electron", "out"]
}
