generator client {
  provider = "prisma-client-js"
  output   = "../prisma/generated/client"
}

generator markdown {
  provider = "prisma-markdown"
  output   = "../prisma/README.md"
  title    = "Desktop DB Schema"
}

datasource db {
  provider = "sqlite"
  url      = env("DESKTOP_DATABASE_URL")
}

/// 接続タイプ
/// @namespace McpServer
enum TransportType {
  /// 標準入出力での通信
  STDIO
  /// Server-Sent Eventsでの通信
  SSE
  /// Streamable HTTPでの通信
  STREAMABLE_HTTP
}

/// 認証タイプ
/// @namespace McpServer
enum AuthType {
  /// 認証不要
  NONE
  /// Bearerトークン認証
  BEARER
  /// APIキー認証
  API_KEY
  /// OAuth認証
  OAUTH
}

/// サーバー状態
/// @namespace McpServer
enum ServerStatus {
  /// 起動中
  RUNNING
  /// 停止
  STOPPED
  /// エラー
  ERROR
  /// 接続検証中
  PENDING
}

/// 監査ログの管理サーバー同期状態
/// @namespace McpServer
enum AuditLogSyncStatus {
  /// 未送信
  PENDING
  /// 送信済み
  SYNCED
  /// 送信失敗（次回以降に再試行）
  FAILED
}

/// サーバーの種類
/// @namespace McpServer
enum ServerType {
  /// カスタムMCPサーバー（ユーザーが既存コネクタを束ねた仮想MCP）
  CUSTOM
  /// 公式MCPサーバー（カタログ/単体カスタム入力で登録した単独コネクタ）
  OFFICIAL
}

/// 認証トークン
/// @namespace Auth
model AuthToken {
  id           Int      @id @default(autoincrement())
  /// 暗号化されたアクセストークン
  accessToken  String
  /// 暗号化されたリフレッシュトークン（jackson OIDC IdP は返さないため nullable）
  refreshToken String?
  /// 暗号化されたIDトークン（OIDCログアウト用）
  idToken      String?
  /// トークンの有効期限
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// MCPカタログ（プリセットMCPサーバーのテンプレート）
/// @namespace McpServer
model McpCatalog {
  id             Int           @id @default(autoincrement())
  /// カタログ表示名
  name           String        @unique
  /// カタログ説明
  description    String        @default("")
  /// アイコンパス
  iconPath       String?
  /// トランスポートタイプ
  transportType  TransportType @default(STDIO)
  /// STDIO用コマンド
  command        String?
  /// STDIO用引数（JSON配列文字列）
  args           String        @default("[]")
  /// SSE/Streamable HTTP用URL
  url            String?
  /// 必要な設定キー名（STDIO: 環境変数キー / SSE・Streamable HTTP: ヘッダー名、JSON配列文字列）
  credentialKeys String        @default("[]")
  /// 認証タイプ
  authType       AuthType      @default(NONE)
  /// 公式カタログフラグ
  isOfficial     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  /// このカタログから作成された接続一覧
  connections McpConnection[]
}

/// MCP接続（個別のMCPサーバーへの接続設定）
/// @namespace McpServer
model McpConnection {
  id            Int           @id @default(autoincrement())
  /// 接続表示名
  name          String
  /// URL識別子（小文字・ハイフン区切り）
  slug          String
  /// トランスポートタイプ
  transportType TransportType @default(STDIO)
  /// STDIO用コマンド（例: "npx", "uvx", "node"）
  command       String?
  /// STDIO用引数（JSON配列文字列）
  args          String        @default("[]")
  /// SSE/Streamable HTTP用URL
  url           String?
  /// 認証タイプ
  authType      AuthType      @default(NONE)
  /// アイコンパス（カスタムMCPのfavicon URL等）
  iconPath      String?
  /// 有効/無効フラグ
  isEnabled     Boolean       @default(true)
  /// 統合サーバー内での表示順序
  displayOrder  Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  /// 所属するMcpServer
  serverId  Int
  server    McpServer   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  /// カタログ参照（カタログから登録した場合）
  catalogId Int?
  catalog   McpCatalog? @relation(fields: [catalogId], references: [id], onDelete: SetNull)
  /// 暗号化済み credentials の格納先（仮想MCPは元コネクタと同じ secretId を共有する）
  /// onDelete: Restrict + アプリ側の参照カウントで孤立した secret のみ削除する運用
  secretId  Int
  secret    McpSecret   @relation(fields: [secretId], references: [id], onDelete: Restrict)

  /// この接続が提供するツール一覧
  tools McpTool[]

  @@unique([serverId, slug])
  /// 参照カウント運用（deleteSecretIfOrphaned の COUNT）と FK 整合性のための索引
  @@index([secretId])
}

/// MCP接続の認証情報（暗号化済み credentials を保持し、複数の McpConnection から共有される）
/// @namespace McpServer
model McpSecret {
  id              Int       @id @default(autoincrement())
  /// 暗号化済み credentials JSON（STDIO: 環境変数 / SSE・Streamable HTTP: HTTPヘッダー / OAuth: トークン）
  /// 必ず encryptToken で暗号化した値を渡す（schema 上のデフォルトを設けると平文 "{}" が紛れ込むため）
  credentials     String
  /// refresh_token が失効しユーザーの手動再認証が必要な状態か。
  /// FATAL なリフレッシュ失敗（invalid_grant 等）を検知したら true、再認証成功でクリア。
  needsReauth     Boolean   @default(false)
  /// 最後に認証エラーを検知した時刻（UI 表示・デバッグ用、TRANSIENT 失敗では更新しない）
  lastAuthErrorAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  /// この secret を参照している接続一覧（参照カウント0で削除可能）
  connections McpConnection[]
}

/// MCPツール（接続が提供するツールの定義・権限管理）
/// @namespace McpServer
model McpTool {
  id                Int      @id @default(autoincrement())
  /// ツール名（大元のMCPから取得、ルーティングに使用）
  name              String
  /// ツール説明（大元のMCPから取得）
  description       String   @default("")
  /// 入力スキーマ（JSON Schema文字列）
  inputSchema       String   @default("{}")
  /// カスタム表示名（nullなら元のnameを使用）
  customName        String?
  /// カスタム説明（nullなら元のdescriptionを使用）
  customDescription String?
  /// ツールの使用を許可するか
  isAllowed         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  /// 対象MCP接続
  connectionId Int
  connection   McpConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  /// 動的検索用のツールembeddingキャッシュ
  embeddingCaches McpToolEmbeddingCache[]

  @@unique([connectionId, name])
}

/// 動的検索用ツールembeddingキャッシュ
/// @namespace McpServer
model McpToolEmbeddingCache {
  id          Int      @id @default(autoincrement())
  /// 対象ツール
  toolId      Int
  tool        McpTool  @relation(fields: [toolId], references: [id], onDelete: Cascade)
  /// embeddingモデルID
  modelId     String
  /// 検索テキスト生成ロジックのバージョン
  textVersion Int
  /// embedding次元数
  dim         Int
  /// 検索テキストのSHA-256
  contentHash String
  /// Float32Arrayをそのまま保存したBLOB
  vector      Bytes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([toolId, modelId, textVersion])
}

/// MCPサーバー（仮想・統合サーバー = Proxyエンドポイント）
/// 1つ以上のMcpConnectionを束ねて1つのMCPサーバーとして公開する
/// @namespace McpServer
model McpServer {
  id                      Int          @id @default(autoincrement())
  /// サーバー表示名
  name                    String
  /// URL識別子（小文字・ハイフン区切り）
  slug                    String       @unique
  /// サーバー説明
  description             String       @default("")
  /// サーバーの種類（OFFICIAL = 単独コネクタ / CUSTOM = 仮想MCP）
  /// 仮想MCP（CUSTOM）の接続を新たな仮想MCPの素材として再ネストするのを防ぐためのフラグ
  serverType              ServerType   @default(OFFICIAL)
  /// サーバー状態
  serverStatus            ServerStatus @default(STOPPED)
  /// 有効/無効フラグ（トグル用）
  isEnabled               Boolean      @default(true)
  /// PII マスキングを有効化するか（false なら upstream に生 args をそのまま渡す）
  isPiiMaskingEnabled     Boolean      @default(true)
  /// TOON 変換（レスポンス圧縮）を有効化するか（true なら tools/call の content[].text を TOON エンコードして AI クライアントに返す）
  isToonConversionEnabled Boolean      @default(false)
  /// 動的検索を有効化するか（有効時は AI クライアントにメタツールのみ公開する）
  dynamicSearch           Boolean      @default(false)
  /// 一覧画面での表示順序
  displayOrder            Int          @default(0)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  /// 個別MCP接続一覧
  connections McpConnection[]
  /// 監査ログ一覧
  auditLogs   AuditLog[]
}

/// OAuthクライアント登録キャッシュ（DCR結果）
/// MCP OAuth認証時のDynamic Client Registration結果をキャッシュし、再登録を回避する
/// @namespace OAuth
model OAuthClient {
  id                      Int      @id @default(autoincrement())
  /// MCPサーバーURL（正規化済み、認可サーバー特定用）
  serverUrl               String   @unique
  /// OAuth Authorization Server issuer URL
  issuer                  String
  /// DCRで取得したクライアントID（暗号化済み）
  clientId                String
  /// DCRで取得したクライアントシークレット（暗号化済み、パブリッククライアントの場合null）
  clientSecret            String?
  /// トークンエンドポイントの認証方式
  tokenEndpointAuthMethod String   @default("none")
  /// Authorization Server Metadata（JSON文字列）
  authServerMetadata      String
  /// DCRで自動登録されたクライアントかどうか（falseの場合はユーザー手動入力）
  isDcr                   Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

/// 監査ログ（MCPツール呼び出しの記録）
/// 7日以上のレコードは自動削除対象
/// @namespace McpServer
model AuditLog {
  id              Int                @id @default(autoincrement())
  /// 実行されたツール名
  toolName        String
  /// MCPメソッド（例: "tools/call", "resources/read"）
  method          String
  /// リクエスト時のトランスポートタイプ
  transportType   TransportType
  /// 実行時間（ミリ秒）
  durationMs      Int
  /// 入力データサイズ（バイト）
  inputBytes      Int                @default(0)
  /// 出力データサイズ（バイト）
  outputBytes     Int                @default(0)
  /// 成功/失敗フラグ
  isSuccess       Boolean            @default(true)
  /// MCPエラーコード（エラー時のみ）
  errorCode       Int?
  /// エラーメッセージ要約
  errorSummary    String?
  /// 操作の補足情報（例: 引数の概要やリソースパス等）
  detail          String?
  /// PII マスキング検出記録 { summary: { TYPE: { count, tokens } }, maskedArgs: {...} }
  /// summary は type 別の件数とマスク後トークン、maskedArgs は upstream に渡された args 全体
  /// null の場合はフィルタ無効 or 検出なし
  piiDetections   Json?
  /// 検出時に適用したマスキングポリシー（mask / detect-only / block）
  /// null の場合はフィルタ無効
  piiPolicy       String?
  /// 管理サーバーへの同期状態
  syncStatus      AuditLogSyncStatus @default(PENDING)
  /// 管理サーバーへの同期完了日時
  syncedAt        DateTime?
  /// 管理サーバーへの同期試行回数
  retryCount      Int                @default(0)
  /// 最後の同期試行日時
  lastSyncTriedAt DateTime?
  createdAt       DateTime           @default(now())

  /// 対象MCPサーバー
  serverId       Int
  server         McpServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
  /// 対象MCP接続名（接続削除後もログで識別可能にするため名前で保持）
  connectionName String?
  /// AIクライアント名（例: "claude-code", "cursor"）
  clientName     String?
  /// AIクライアントバージョン
  clientVersion  String?

  @@index([serverId, createdAt])
  @@index([createdAt])
  @@index([syncStatus, createdAt])
}
