{
  "name": "@tumiki/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/index.cjs",
  "scripts": {
    "dev": "pnpm with-env electron-vite dev",
    "build": "pnpm with-env electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "clean": "git clean -xdf .cache .turbo node_modules dist-electron out",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --",
    "lint": "eslint",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path ../../.prettierignore",
    "test": "vitest",
    "db:generate": "pnpm with-env prisma generate",
    "db:migrate": "pnpm with-env prisma migrate dev",
    "db:deploy": "pnpm with-env prisma migrate deploy",
    "db:reset": "pnpm with-env prisma migrate reset",
    "db:push": "pnpm with-env prisma db push",
    "db:studio": "pnpm with-env prisma studio",
    "postinstall": "pnpm db:generate",
    "build:release": "electron-builder --config electron-builder.yml --publish never"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/react-query": "catalog:",
    "@tumiki/db": "workspace:*",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "jotai": "^2.18.0",
    "lucide-react": "^0.486.0",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-router-dom": "^7.5.0",
    "recharts": "3.8.0",
    "sonner": "^1.7.4",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "zod": "catalog:"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@tumiki/tailwind-config": "workspace:*",
    "@tumiki/tsconfig": "workspace:*",
    "@tumiki/vitest-config": "workspace:*",
    "@types/node": "^22.19.10",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@typescript/native-preview": "7.0.0-dev.20260405.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "catalog:",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^6.19.0",
    "prisma-markdown": "^2.0.0",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.48.1",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
