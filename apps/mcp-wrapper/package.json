{
  "name": "@tumiki/mcp-wrapper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm with-env tsx watch src/index.ts",
    "build": "pnpm build:clean && tsc --project tsconfig.build.json",
    "build:clean": "rm -rf dist .cache",
    "start": "pnpm with-env node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --",
    "with-env-test": "dotenv -e ../../.env.test --",
    "lint": "eslint",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@tumiki/db": "workspace:*",
    "hono": "^4.12.6"
  },
  "devDependencies": {
    "@tumiki/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "dotenv-cli": "^11.0.0",
    "eslint": "catalog:",
    "eslint-plugin-headers": "^1.3.3",
    "eslint-plugin-import": "^2.32.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.48.1",
    "vitest": "catalog:"
  }
}
