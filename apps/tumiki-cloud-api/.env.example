# サーバー設定
PORT=8081
NODE_ENV=development

# TLS/mTLS 設定（本番環境のみ）
# TLS_CERT=<PEMエンコードされたサーバー証明書>
# TLS_KEY=<PEMエンコードされた秘密鍵>
# RAYVEN_CA_CERT=<PEMエンコードされたCA証明書（クライアント証明書検証用）>

# Bootstrap Token 検証（RAYVEN が発行する JWT の公開鍵）
# BOOTSTRAP_TOKEN_PUBLIC_KEY=<RS256 SPKI 形式の公開鍵>

# Infisical PKI（証明書署名用）
# INFISICAL_URL=https://secrets.rayven.cloud
# INFISICAL_API_TOKEN=<Infisical Universal Auth トークン>
# INFISICAL_CA_ID=<証明書テンプレートの CA ID>
# CERT_TTL=2160h
