# tumiki-cloud-api 環境変数
# 本番では Infisical で管理し、Operator が k8s Secret に同期する

# サーバー設定
PORT=8080
NODE_ENV=development

# ライセンス JWT 検証用 RS256 公開鍵（PEM 形式）
# 改行を \n でエスケープ or 複数行のヒアドキュメントで設定する
LICENSE_PUBLIC_KEY=

# Vercel AI Gateway API キー
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# 使用モデル（省略時: anthropic/claude-3.5-haiku）
DYNAMIC_SEARCH_MODEL=anthropic/claude-3.5-haiku
