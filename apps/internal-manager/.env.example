# ============================================================
# internal-manager 環境変数
# 社内サーバー上でホスティングする際に設定してください
# ============================================================

# ---- Auth.js ----
AUTH_SECRET=                          # openssl rand -base64 32 で生成

# ---- OIDC プロバイダー設定 ----
# 社内 IdP (Entra ID / Google Workspace / Okta / Keycloak 等) の情報を設定
#
# Entra ID の場合:
#   OIDC_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
#
# Google Workspace の場合:
#   OIDC_ISSUER=https://accounts.google.com
#
# Okta の場合:
#   OIDC_ISSUER=https://{your-domain}.okta.com
#
# Keycloak の場合:
#   OIDC_ISSUER=https://{keycloak-host}/realms/{realm-name}
#
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER=

# ---- Database ----
DATABASE_URL=postgresql://user:password@localhost:5432/tumiki

# ---- Prisma フィールド暗号化 ----
# @47ng/cloak で生成: npx @47ng/cloak generate
PRISMA_FIELD_ENCRYPTION_KEY=
PRISMA_FIELD_ENCRYPTION_HASH_SALT=    # openssl rand -base64 32 で生成
