{
  "extends": "@tumiki/tsconfig/nextjs.json",
  "compilerOptions": {
    "verbatimModuleSyntax": true,
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./src/*"],
      "@db-client": ["./prisma/generated/client"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.cjs",
    "**/*.js",
    ".next/types/**/*.ts",
    "postcss.config.mjs"
  ],
  "exclude": [
    "node_modules",
    "coverage",
    "prisma/generated",
    "prisma.config.ts"
  ]
}
