{
  "name": "@tumiki/tenant-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PORT=3200 pnpm with-env next dev --turbopack",
    "build": "pnpm with-env next build --turbopack",
    "build:bare": "next build --webpack",
    "start": "PORT=3200 pnpm with-env next start",
    "start:prod": "PORT=3200 pnpm with-env:prod next start",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "typecheck": "tsc --noEmit",
    "with-env": "infisical run --env=dev --",
    "with-env:prod": "infisical run --env=prod --",
    "lint": "eslint",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "check": "concurrently --kill-others-on-fail --names \"lint,format,typecheck\" \"pnpm run lint\" \"pnpm run format\" \"pnpm run typecheck\""
  },
  "dependencies": {
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "11.12.0",
    "@trpc/react-query": "11.12.0",
    "@trpc/server": "11.12.0",
    "@tumiki/tenant-db": "workspace:*",
    "@tumiki/ui": "workspace:*",
    "lucide-react": "^0.486.0",
    "next": "^16.1.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
    "superjson": "^2.2.6",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@tumiki/tsconfig": "workspace:*",
    "@types/node": "^22.19.10",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "concurrently": "^9.2.1",
    "eslint": "catalog:",
    "postcss": "^8.5.6",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.48.1"
  }
}
