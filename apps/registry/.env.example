# Tumiki Registry - 環境変数サンプル

# Slack Incoming Webhook（お問い合わせフォーム通知先）
# Slack App → Incoming Webhooks → Webhook URL を設定
SLACK_CONTACT_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXX

# Keycloak認証（Registry専用）
REGISTRY_KEYCLOAK_CLIENT_ID=
REGISTRY_KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER=https://your-keycloak.example.com/realms/tumiki
