{
  "name": "@tumiki/registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PORT=3100 pnpm with-env next dev --turbopack",
    "build": "pnpm with-env next build --turbopack",
    "start": "PORT=3100 pnpm with-env next start",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --",
    "lint": "eslint",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "check": "concurrently --kill-others-on-fail --names \"lint,format,typecheck\" \"pnpm run lint\" \"pnpm run format\" \"pnpm run typecheck\""
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "11.12.0",
    "@trpc/react-query": "11.12.0",
    "@trpc/server": "11.16.0",
    "@tumiki/db": "workspace:*",
    "@tumiki/keycloak": "workspace:*",
    "@tumiki/ui": "workspace:*",
    "next": "^16.1.5",
    "next-auth": "5.0.0-beta.30",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
    "superjson": "^2.2.6",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@tumiki/tsconfig": "workspace:*",
    "@types/node": "^22.19.10",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "catalog:",
    "postcss": "^8.5.6",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.48.1"
  }
}
