{
  "$schema": "https://turborepo.org/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "INTERNAL_DATABASE_URL",
    "PRISMA_FIELD_ENCRYPTION_KEY",
    "PRISMA_FIELD_ENCRYPTION_HASH_SALT",
    "OIDC_CLIENT_ID",
    "OIDC_CLIENT_SECRET",
    "OIDC_ISSUER",
    "OIDC_DESKTOP_CLIENT_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", "out/**", "dist-electron/**", ".next/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "format": {
      "outputs": [".cache/.prettiercache"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": [".cache/.eslintcache"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "@tumiki/mcp-core-proxy#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@tumiki/desktop#typecheck": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": []
    },
    "@tumiki/desktop#db:generate": {
      "outputs": ["prisma/generated/**"]
    },
    "@tumiki/internal-db#db:generate": {
      "outputs": ["generated/**"]
    },
    "@tumiki/internal-db#typecheck": {
      "dependsOn": ["^build", "db:generate"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
